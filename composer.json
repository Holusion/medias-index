{
    "name": "holusion/medias-index",
    "description": "Indexes a tree of static content folders and lists them with links and embed snippets",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-gd": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "MediasIndex\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MediasIndex\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "doctor": "php bin/doctor.php"
    }
}
